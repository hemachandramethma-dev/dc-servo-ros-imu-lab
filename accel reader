/*
  Activity 3: MPU6050 Accelerometer vs Wheel Angle
  ---------------------------------------------------
  Reads accelerometer X, Y, Z from the MPU6050 mounted on the wheel
  (Z axis aligned with the rotation axle), applies a low-pass filter,
  and streams angle + acceleration data over Serial for logging.

  CSV line format sent over serial:
    <wheel_angle_deg>,<accelX_g>,<accelY_g>,<accelZ_g>

  NOTE: ALPHA was originally 0.05, which caused ~2 seconds of filter
  lag and masked the expected sinusoidal X/Y pattern. Raising it to
  0.2 fixed this.
*/

#include <Wire.h>

constexpr uint8_t MPU_ADDR = 0x68;

constexpr uint8_t ENCODER_C1 = 19;
constexpr uint8_t ENCODER_C2 = 18;
constexpr float TICKS_PER_REV = 2058.0f;

volatile long encoderTicks = 0;

void IRAM_ATTR readEncoder() {
    int bState = digitalRead(ENCODER_C2);
    if (bState == HIGH) encoderTicks++;
    else                 encoderTicks--;
}

// --- Low-pass filter ---
constexpr float ALPHA = 0.2f;

float filteredX = 0, filteredY = 0, filteredZ = 0;

void readAccel(float &ax, float &ay, float &az) {
    Wire.beginTransmission(MPU_ADDR);
    Wire.write(0x3B);  // ACCEL_XOUT_H register
    Wire.endTransmission(false);
    Wire.requestFrom(MPU_ADDR, 6, true);

    int16_t rawX = (Wire.read() << 8) | Wire.read();
    int16_t rawY = (Wire.read() << 8) | Wire.read();
    int16_t rawZ = (Wire.read() << 8) | Wire.read();

    // +-2g range -> divide by 16384 to convert to g
    ax = rawX / 16384.0f;
    ay = rawY / 16384.0f;
    az = rawZ / 16384.0f;
}

void setup() {
    Serial.begin(115200);
    Wire.begin();

    // Wake up MPU6050 (it starts in sleep mode by default)
    Wire.beginTransmission(MPU_ADDR);
    Wire.write(0x6B);
    Wire.write(0);
