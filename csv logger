"""
csv_logger.py
--------------
Subscribes to /encoder_angle and writes a timestamped log to CSV.
"""

import rclpy
from rclpy.node import Node
from std_msgs.msg import Float32
import csv
import time


OUTPUT_FILE = 'response_log.csv'


class CsvLogger(Node):
    def __init__(self):
        super().__init__('csv_logger')

        self.declare_parameter('target_angle', 90.0)
        self.target_angle = self.get_parameter('target_angle').value

        self.file = open(OUTPUT_FILE, mode='w', newline='')
        self.writer = csv.writer(self.file)
        self.writer.writerow(['Time_s', 'Target_Deg', 'Current_Deg', 'Error_Deg'])

        self.start_time = time.time()

        self.subscription = self.create_subscription(
            Float32, '/encoder_angle', self.angle_callback, 10
        )

        self.get_logger().info(f'Logging to {OUTPUT_FILE} (target={self.target_angle})')

    def angle_callback(self, msg: Float32):
        elapsed = round(time.time() - self.start_time, 3)
        current = msg.data
        error = self.target_angle - current

        self.writer.writerow([elapsed, self.target_angle, current, error])
        self.file.flush()


def main(args=None):
    rclpy.init(args=args)
    node = CsvLogger()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.file.close()
        node.get_logger().info('Log file closed.')
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
